 // static
 uint64_t CanvasNoiseTokenData::GetBrowserToken(BrowserContext* context) {
+  // If the browser was launched with --canvas-noise=<token>, use that token
+  // as the stable browser token. This allows tests or manual runs to force a
+  // deterministic token. The switch value may be provided as decimal or
+  // hexadecimal (0x...).
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (cmd->HasSwitch("canvas-noise")) {
+    std::string val = cmd->GetSwitchValueASCII("canvas-noise");
+    uint64_t parsed = 0;
+    // Support 0x... hex and decimal values.
+    if (!val.empty()) {
+      if (val.size() > 2 && val[0] == '0' && (val[1] == 'x' || val[1] == 'X')) {
+        // Hex string: remove 0x and parse as base 16.
+        std::string hex = val.substr(2);
+        // base::StringToUint64 accepts hex when base is 16.
+        if (base::HexStringToUInt64(hex, &parsed))
+          return parsed;
+      } else {
+        // Try decimal first, then hex fallback (if prefixed differently).
+        if (base::StringToUint64(val, &parsed))
+          return parsed;
+        // As a last resort, try hex parse without 0x.
+        if (base::HexStringToUInt64(val, &parsed))
+          return parsed;
+      }
+    }
+    // If parsing fails, fall through to normal behavior.
+  }
+
   CHECK(base::FeatureList::IsEnabled(
       fingerprinting_protection_interventions::features::kCanvasNoise));
 
