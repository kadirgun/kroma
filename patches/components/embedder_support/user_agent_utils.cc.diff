+std::optional<std::string> GetUserAgentVersionFromCommandLine() {
+  base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  if (command_line->HasSwitch(kUserAgentVersion)) {
+    std::string version = command_line->GetSwitchValueASCII(kUserAgentVersion);
+    // Basic validation: check if version looks like x.y.z.w format
+    if (!version.empty() && version.find_first_not_of("0123456789.") == std::string::npos) {
+      return version;
+    }
+    LOG(WARNING) << "Ignored invalid value for flag --" << kUserAgentVersion;
+  }
+  return std::nullopt;
+}
+
+std::string GetVersionNumber() {
+  std::optional<std::string> custom_version = GetUserAgentVersionFromCommandLine();
+  return custom_version.has_value() 
+      ? custom_version.value() 
+      : std::string(version_info::GetVersionNumber());
+}
+
+std::string GetMajorVersionNumber() {
+  std::optional<std::string> custom_version = GetUserAgentVersionFromCommandLine();
+  if (custom_version.has_value()) {
+    size_t dot_pos = custom_version.value().find('.');
+    if (dot_pos != std::string::npos) {
+      return custom_version.value().substr(0, dot_pos);
+    }
+    return custom_version.value(); // fallback if no dot found
+  }
+  return version_info::GetMajorVersionNumber();
+}
