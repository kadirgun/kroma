+    // Apply canvas readback noise for fingerprinting protection when
+    // the feature is enabled and the readback is RGBA/UNSIGNED_BYTE.
+    // The 2D canvas implementation applies NoisePixels on SkBitmap pixels;
+    // here we apply noise in-place on the raw readback buffer.
+    if (format == GL_RGBA && type == GL_UNSIGNED_BYTE && data &&
+        GetExecutionContext()) {
+      auto* execution_context = GetExecutionContext();
+      // Only apply when the page has a canvas noise token set.
+      if (execution_context->CanvasNoiseToken().has_value()) {
+        size_t pixel_count = static_cast<size_t>(width) *
+                            static_cast<size_t>(height);
+        // Compute required bytes and verify against the provided buffer to
+        // avoid unsafe buffer usage. ValidateReadPixelsFuncParameters should
+        // have ensured the buffer is large enough, but make the check
+        // explicit to satisfy static analysis.
+        size_t needed_bytes = 0;
+        if (!base::CheckedNumeric<size_t>(pixel_count)
+                 .AssignIfValid(&needed_bytes) ||
+            !base::CheckedNumeric<size_t>(needed_bytes)
+                 .AssignIfValid(&needed_bytes)) {
+          needed_bytes = pixel_count * 4u;
+        }
+        // Multiply by 4 (RGBA8) with overflow protection.
+        base::CheckedNumeric<size_t> checked_needed = pixel_count;
+        checked_needed *= 4u;
+        if (!checked_needed.IsValid())
+          return;
+        needed_bytes = checked_needed.ValueOrDie();
+
+        size_t available_bytes =
+            static_cast<size_t>(pixels->byteLength()) -
+            static_cast<size_t>(offset_in_bytes.ValueOrDie());
+        // If the provided buffer is unexpectedly too small, bail out safely.
+        // ValidateReadPixelsFuncParameters should normally prevent this, but
+        // make the check explicit for static analysis and defense in depth.
+        if (needed_bytes > available_bytes) {
+          return;
+        }
+        DCHECK_LE(needed_bytes, available_bytes);
+        // Prefer the safe ByteSpanMaybeShared API which returns a span
+        // backed by the ArrayBufferView's backing store if present. Use a
+        // subspan starting at the validated offset so static analysis can
+        // verify safety.
+        auto bytes_span = pixels->ByteSpanMaybeShared().subspan(
+          static_cast<size_t>(offset_in_bytes.ValueOrDie()));
+        // bytes_span may be larger than needed_bytes; take the prefix we
+        // actually need using span::first which avoids creating a new span
+        // from a raw pointer/length pair (silences the static analyzer).
+        DCHECK_GE(bytes_span.size(), needed_bytes);
+        auto pixels_span = bytes_span.first(needed_bytes);
+        // First do a lightweight entropy sample. If the sampled Shannon
+        // entropy is low, skip applying noise to avoid unnecessary
+        // perturbation for low-entropy readbacks.
+        constexpr double kEntropyThreshold = 5.0;  // bits
+        if (blink::CanvasInterventionsHelper::IsLikelyHighEntropy(
+          execution_context, pixels_span, kEntropyThreshold)) {
+          auto token_hash = blink::NoiseHash(execution_context->CanvasNoiseToken().value());
+          blink::NoisePixels(token_hash, pixels_span, width, height);
+        }
+      }
