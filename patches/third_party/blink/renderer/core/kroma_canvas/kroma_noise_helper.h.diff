+#ifndef THIRD_PARTY_BLINK_RENDERER_CORE_KROMA_CANVAS_KROMA_NOISE_HELPER_H_
+#define THIRD_PARTY_BLINK_RENDERER_CORE_KROMA_CANVAS_KROMA_NOISE_HELPER_H_
+
+#include <cstdint>
+
+#include "base/containers/span.h"
+#include "third_party/blink/renderer/core/kroma_canvas/kroma_noise_hash.h"
+#include "third_party/blink/renderer/core/core_export.h"
+
+namespace blink {
+
+// Returns true if canvas has sufficient color variation (high entropy).
+// Skips pure white pixels for performance. |entropy_threshold| is the
+// minimum number of distinct luminance bins required.
+CORE_EXPORT bool KromaIsLikelyHighEntropy(base::span<uint8_t> pixels_rgba,
+                                          int width,
+                                          int height,
+                                          double entropy_threshold);
+
+// Adds noise to the provided pixels in place, using |token_hash| as the
+// source for pseudo-randomness. This function assumes that there are 4
+// channels per pixel.
+CORE_EXPORT void KromaNoisePixels(const KromaNoiseHash& token_hash,
+                                 base::span<uint8_t> pixels,
+                                 const int width,
+                                 const int height);
+
+// Adds a tiny deterministic offset to a geometry value, using the provided
+// canvas noise token value and salt to derive the pseudo-random delta.
+CORE_EXPORT double KromaNoiseDouble(uint64_t token_value,
+                                    uint64_t salt,
+                                    double value);
+
+// Float overload for geometry values stored as floats.
+CORE_EXPORT float KromaNoiseFloat(uint64_t token_value,
+                                 uint64_t salt,
+                                 float value);
+
+}  // namespace blink
+
+#endif  // THIRD_PARTY_BLINK_RENDERER_CORE_KROMA_CANVAS_KROMA_NOISE_HELPER_H_
