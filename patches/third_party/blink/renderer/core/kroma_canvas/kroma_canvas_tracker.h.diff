+#ifndef THIRD_PARTY_BLINK_RENDERER_CORE_KROMA_CANVAS_KROMA_CANVAS_TRACKER_H_
+#define THIRD_PARTY_BLINK_RENDERER_CORE_KROMA_CANVAS_KROMA_CANVAS_TRACKER_H_
+
+#include <cstdint>
+
+namespace blink {
+
+// Kroma's own canvas operation tracking enum - independent from Chromium's
+// HighEntropyCanvasOpType which is being deprecated.
+enum class KromaCanvasOp : uint32_t {
+  kNone = 0,
+  kFillText = 1 << 0,
+  kStrokeText = 1 << 1,
+  kDrawImage = 1 << 2,
+  kPutImageData = 1 << 3,
+  kArc = 1 << 4,
+  kEllipse = 1 << 5,
+  kCopyFromCanvas = 1 << 6,
+};
+
+// Lightweight canvas operation tracker for fingerprinting protection decisions.
+// This is Kroma's own system, independent of Chromium's identifiability study
+// and HighEntropyCanvasOpType which are being removed.
+class KromaCanvasTracker {
+public:
+  void RecordFillText() { ops_ = static_cast<KromaCanvasOp>(static_cast<uint32_t>(ops_) | static_cast<uint32_t>(KromaCanvasOp::kFillText)); }
+  void RecordStrokeText() { ops_ = static_cast<KromaCanvasOp>(static_cast<uint32_t>(ops_) | static_cast<uint32_t>(KromaCanvasOp::kStrokeText)); }
+  void RecordDrawImage() { ops_ = static_cast<KromaCanvasOp>(static_cast<uint32_t>(ops_) | static_cast<uint32_t>(KromaCanvasOp::kDrawImage)); }
+  void RecordPutImageData() { ops_ = static_cast<KromaCanvasOp>(static_cast<uint32_t>(ops_) | static_cast<uint32_t>(KromaCanvasOp::kPutImageData)); }
+  void RecordArc() { ops_ = static_cast<KromaCanvasOp>(static_cast<uint32_t>(ops_) | static_cast<uint32_t>(KromaCanvasOp::kArc)); }
+  void RecordEllipse() { ops_ = static_cast<KromaCanvasOp>(static_cast<uint32_t>(ops_) | static_cast<uint32_t>(KromaCanvasOp::kEllipse)); }
+  void RecordCopyFromCanvas() { ops_ = static_cast<KromaCanvasOp>(static_cast<uint32_t>(ops_) | static_cast<uint32_t>(KromaCanvasOp::kCopyFromCanvas)); }
+
+  bool HasOperations() const { return ops_ != KromaCanvasOp::kNone; }
+  uint32_t GetOperations() const { return static_cast<uint32_t>(ops_); }
+  void Reset() { ops_ = KromaCanvasOp::kNone; }
+
+private:
+  KromaCanvasOp ops_ = KromaCanvasOp::kNone;
+};
+
+}  // namespace blink
+
+#endif  // THIRD_PARTY_BLINK_RENDERER_CORE_KROMA_CANVAS_KROMA_CANVAS_TRACKER_H_
