+// Block-anchor + quantize helpers.
+// The block-anchor deterministically picks one pixel per block (based on
+// token_hash) which will always receive noise. The quantize helper counts
+// distinct quantized colors in a small neighborhood to detect smooth
+// gradients / low-color regions where gradient pixels should be considered
+// part of the same shape and thus be forced to receive noise.
+constexpr int kBlockSize = 16;
+constexpr int kQuantWindowSize = 5;  // 5x5 window
+constexpr int kQuantShift = 5;       // quantize to 3 bits per channel (>>5)
+constexpr int kQuantDistinctThreshold = 3;
+
+bool IsBlockAnchorPixel(const NoiseHash& token_hash,
+                        int x,
+                        int y,
+                        int width,
+                        int height) {
+  int block_x = x / kBlockSize;
+  int block_y = y / kBlockSize;
+  NoiseHash h = token_hash;
+  // Mix block coords into hash deterministically.
+  uint64_t v = (static_cast<uint64_t>(static_cast<uint32_t>(block_x)) << 32) |
+               static_cast<uint64_t>(static_cast<uint32_t>(block_y));
+  h.Update(v);
+  int ax = h.GetValueBelow(kBlockSize);
+  int ay = h.GetValueBelow(kBlockSize);
+  int anchor_x = block_x * kBlockSize + ax;
+  int anchor_y = block_y * kBlockSize + ay;
+  // Clamp anchor to canvas.
+  anchor_x = std::min(anchor_x, width - 1);
+  anchor_y = std::min(anchor_y, height - 1);
+  return (x == anchor_x && y == anchor_y);
+}
+
+int QuantizedDistinctColorsCount(const base::span<uint8_t> pixels,
+                                 int width,
+                                 int height,
+                                 int cx,
+                                 int cy) {
+  const int half = kQuantWindowSize / 2;
+  uint32_t uniques[kQuantWindowSize * kQuantWindowSize];
+  int unique_count = 0;
+  for (int dy = -half; dy <= half; ++dy) {
+    int ny = cy + dy;
+    if (ny < 0 || ny >= height)
+      continue;
+    for (int dx = -half; dx <= half; ++dx) {
+      int nx = cx + dx;
+      if (nx < 0 || nx >= width)
+        continue;
+      auto p = GetPixelAt(nx, ny, width, pixels);
+      if (p == kEmptyPixel)
+        continue;
+      uint32_t key = ((static_cast<uint32_t>(p[0]) >> kQuantShift) << 16) |
+                     ((static_cast<uint32_t>(p[1]) >> kQuantShift) << 8) |
+                     (static_cast<uint32_t>(p[2]) >> kQuantShift);
+      bool found = false;
+      for (int i = 0; i < unique_count; ++i) {
+        if (uniques[i] == key) {
+          found = true;
+          break;
+        }
+      }
+      if (!found) {
+        uniques[unique_count++] = key;
+        if (unique_count > kQuantDistinctThreshold)
+          return unique_count;
+      }
+    }
+  }
+  return unique_count;
+}
