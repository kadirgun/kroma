+// Cache of previously noised pixel digests. We store a map from digest ->
+// boolean (true) to indicate presence. The boolean value is unused but keeps
+// the API flexible for future metadata.
+static std::map<base::SHA1Digest, bool>* GetNoisedPixelsCache() {
+  static base::NoDestructor<std::map<base::SHA1Digest, bool>> cache;
+  return cache.get();
+}
+
+// Compute SHA1 key from pixels + width + height. We include width and height
+// as little-endian 32-bit integers to avoid collisions across different
+// canvas sizes with the same raw bytes.
+static base::SHA1Digest ComputePixelsKey(const base::span<uint8_t> pixels,
+                                        int width,
+                                        int height) {
+  // Build a temporary buffer: pixels + width(4 bytes LE) + height(4 bytes LE).
+  std::vector<uint8_t> buffer;
+  buffer.reserve(pixels.size() + 8);
+  buffer.insert(buffer.end(), pixels.begin(), pixels.end());
+  // Append width and height as 32-bit little endian.
+  uint32_t w = static_cast<uint32_t>(width);
+  uint32_t h = static_cast<uint32_t>(height);
+  auto w_bytes = base::U32ToLittleEndian(w);
+  auto h_bytes = base::U32ToLittleEndian(h);
+  buffer.insert(buffer.end(), w_bytes.begin(), w_bytes.end());
+  buffer.insert(buffer.end(), h_bytes.begin(), h_bytes.end());
+  return base::SHA1Hash(
+      base::as_bytes(base::span<const uint8_t>(buffer.data(), buffer.size())));
+}
