index f5c0db2d1b58de1fb54aa6545de8ac0fb177319e..81fa0a5280d398b2ef6437069b1fa0154f9a8d76 100644
--- a/third_party/blink/renderer/core/frame/navigator_concurrent_hardware.cc
+++ b/third_party/blink/renderer/core/frame/navigator_concurrent_hardware.cc
@@ -5,10 +5,22 @@
 #include "third_party/blink/renderer/core/frame/navigator_concurrent_hardware.h"
 
 #include "base/system/sys_info.h"
+#include "base/command_line.h"
+#include "base/strings/string_number_conversions.h"
 
 namespace blink {
 
 unsigned NavigatorConcurrentHardware::hardwareConcurrency() const {
+  // If embedder/launcher passed --cpu-cores, prefer that explicit override.
+  const base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  if (cmd && cmd->HasSwitch("cpu-cores")) {
+    std::string value = cmd->GetSwitchValueASCII("cpu-cores");
+    unsigned parsed = 0u;
+    if (base::StringToUint(value, &parsed) && parsed > 0u)
+      return parsed;
+    // If parsing failed or parsed is 0, fall through to normal behavior.
+  }
+  
   return static_cast<unsigned>(base::SysInfo::NumberOfProcessors());
 }
 
