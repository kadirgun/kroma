 void Port::FinishAddingAddress(const Candidate& c, bool is_final) {
-  candidates_.push_back(c);
-  NotifyCandidateReady(this, c);
+  Candidate c_to_add = c;
+
+  base::CommandLine* cmd = base::CommandLine::ForCurrentProcess();
+  // Diagnostic: log whether the visitor-ip switch is visible in this process
+  // and what its value is. When present, use it to override candidate
+  // addresses. Do NOT force an inline value here — that was only for
+  // temporary testing.
+  bool visitor_switch_present = false;
+  std::string visitor_switch_value;
+  if (cmd) {
+    visitor_switch_present = cmd->HasSwitch("visitor-ip");
+    if (visitor_switch_present)
+      visitor_switch_value = cmd->GetSwitchValueASCII("visitor-ip");
+  }
+  // Visitor switch presence/value logged only at higher-level diagnostics.
+
+  if (visitor_switch_present &&
+      (c_to_add.is_local() || c_to_add.type() == IceCandidateType::kSrflx)) {
+    std::string visitor_ip = visitor_switch_value;
+    int port = c_to_add.address().port();
+    SocketAddress new_addr(visitor_ip, port);
+  // Override candidate IP with visitor IP; preserve port.
+    c_to_add.set_address(new_addr);
+  }
+
+  candidates_.push_back(c_to_add);
+
+  NotifyCandidateReady(this, c_to_add);
 
   PostAddAddress(is_final);
 }
