diff --git a/chrome/common/crash_keys.cc b/chrome/common/crash_keys.cc
index e0681b4483..d87fa51ef2 100644
--- a/chrome/common/crash_keys.cc
+++ b/chrome/common/crash_keys.cc
@@ -51,12 +51,24 @@ class CrashKeyWithName {
   ~CrashKeyWithName() = delete;
 
   std::string_view Name() const { return name_; }
-  std::string_view Value() const { return crash_key_.value(); }
-  void Clear() { crash_key_.Clear(); }
-  void Set(std::string_view value) { crash_key_.Set(value); }
+  // Return the last value that was set for this crash key. The underlying
+  // CrashKeyString implementation (Breakpad variant) does not provide a
+  // getter, so we cache the value here when Set() is called.
+  std::string_view Value() const { return value_; }
+  void Clear() {
+    value_.clear();
+    crash_key_.Clear();
+  }
+  void Set(std::string_view value) {
+    value_.assign(value);
+    crash_key_.Set(value_);
+  }
 
  private:
   std::string name_;
+  // Cache the last-set value so Value() can return it even when the
+  // underlying CrashKeyString implementation doesn't expose a getter.
+  std::string value_;
   crash_reporter::CrashKeyString<64> crash_key_;
 };
 
