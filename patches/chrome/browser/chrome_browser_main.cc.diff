diff --git a/chrome/browser/chrome_browser_main.cc b/chrome/browser/chrome_browser_main.cc
index b4160da8ba3764f3d0233f6c8228e3978df4f1dd..dc57128cfde923a8b46760d4c1cafcda9a3763b1 100644
--- a/chrome/browser/chrome_browser_main.cc
+++ b/chrome/browser/chrome_browser_main.cc
@@ -53,6 +53,7 @@
 #include "chrome/browser/metrics/expired_histograms_array.h"
 #include "chrome/browser/metrics/shutdown_watcher_helper.h"
 #include "chrome/browser/net/system_network_context_manager.h"
+#include "chrome/browser/net/secure_dns_config.h"
 #include "chrome/browser/performance_manager/public/chrome_browser_main_extra_parts_performance_manager.h"
 #include "chrome/browser/performance_monitor/chrome_browser_main_extra_parts_performance_monitor.h"
 #include "chrome/browser/policy/chrome_browser_policy_connector.h"
@@ -1200,6 +1201,32 @@ int ChromeBrowserMainParts::PreCreateThreadsImpl() {
 
   PrefService* local_state = browser_process_->local_state();
 
+  // If the --doh-template command-line switch is provided, use it to set the
+  // dns_over_https.templates pref unless the pref is managed by policy.
+  if (base::CommandLine::ForCurrentProcess()->HasSwitch(
+          switches::kDohTemplate)) {
+    std::string doh_template =
+        base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+            switches::kDohTemplate);
+    if (!doh_template.empty()) {
+      if (!local_state->IsManagedPreference(prefs::kDnsOverHttpsTemplates)) {
+        VLOG(1) << "Setting dns_over_https.templates from --doh-template";
+        local_state->SetString(prefs::kDnsOverHttpsTemplates, doh_template);
+        // Also set the DoH mode to 'automatic' so the template is used
+        // immediately, unless the mode pref is managed by policy.
+        if (!local_state->IsManagedPreference(prefs::kDnsOverHttpsMode)) {
+          VLOG(1) << "Setting dns_over_https.mode to 'automatic' from --doh-template";
+          local_state->SetString(prefs::kDnsOverHttpsMode,
+                                 SecureDnsConfig::kModeAutomatic);
+        } else {
+          VLOG(1) << "dns_over_https.mode is managed by policy; not overriding";
+        }
+      } else {
+        VLOG(1) << "--doh-template ignored because dns_over_https.templates is managed by policy";
+      }
+    }
+  }
+
 #if BUILDFLAG(IS_CHROMEOS)
   browser_process_->platform_part()->InitializeCrosSettings();
   ash::StatsReportingController::Initialize(local_state);
