+  // Ensure the --visitor-ip switch (if provided to the browser) is
+  // forwarded to renderer child processes so that code running in
+  // renderer-based components (like WebRTC) can read the switch directly.
+  if (browser_command_line.HasSwitch("visitor-ip")) {
+    command_line->AppendSwitchASCII(
+        "visitor-ip",
+        browser_command_line.GetSwitchValueASCII("visitor-ip"));
