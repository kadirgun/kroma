+  // Generate AppUserModelId for the browser without including the profile id,
+  // so all Chromium browser windows (any profile) share the same AUMID and are
+  // grouped under the same taskbar icon.
+  // NOTE: This will prevent per-profile pinned icons / separate jump lists.
+  // Ensure this trade-off is acceptable before enabling in production.
+  std::vector<std::wstring> components;
